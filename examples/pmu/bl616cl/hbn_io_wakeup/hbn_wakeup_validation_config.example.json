{
  "build": {
    "enabled": true,
    "chip": "bl616cl",
    "board": "bl616cldk",
    "extra_args": []
  },
  "flash": {
    "enabled": true,
    "port": "/dev/ttyUSB0",
    "extra_args": []
  },
  "serial": {
    "dut": {
      "port": "/dev/ttyUSB0",
      "baudrate": 2000000,
      "run_reset_on_open": true,
      "reset_pulse_ms": 5,
      "boot_wait_ms": 200,
      "dtr_low_is_true": true,
      "rts_low_is_true": true
    },
    "dft": {
      "port": "/dev/ttyACM0",
      "baudrate": 2000000,
      "run_reset_on_open": true,
      "reset_pulse_ms": 5,
      "boot_wait_ms": 200,
      "dtr_low_is_true": true,
      "rts_low_is_true": true
    }
  },
  "timing": {
    "startup_drain_ms": 1500,
    "dft_settle_ms": 5,
    "ready_delay_ms": 10,
    "edge_hold_ms": 5,
    "level_hold_ms": 5,
    "wakeup_timeout_ms": 3000,
    "dut_ready_timeout_ms": 1500,
    "dut_command_timeout_ms": 1500,
    "dft_command_timeout_ms": 1000,
    "post_wakeup_settle_ms": 150,
    "quiet_after_parse_ms": 50
  },
  "retries": {
    "dut_command_max_retries": 2,
    "dft_command_max_retries": 2
  },
  "tests": {
    "hbn_modes": [0, 1],
    "pins": [
      { "dut_gpio": 0, "dft_gpio": 0 },
      { "dut_gpio": 1, "dft_gpio": 1 },
      { "dut_gpio": 2, "dft_gpio": 2 },
      { "dut_gpio": 3, "dft_gpio": 3 },
      { "dut_gpio": 4, "dft_gpio": 4 },
      { "dut_gpio": 5, "dft_gpio": 5 }
    ],
    "triggers": [
      "sync_fall",
      "sync_rise",
      "sync_low",
      "sync_high",
      "sync_both",
      "async_fall",
      "async_rise",
      "async_low",
      "async_high"
    ]
  }
}
