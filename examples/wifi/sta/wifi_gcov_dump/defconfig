-include $(BL_SDK_BASE)/examples/wifi/defconfig

CONFIG_MBEDTLS_AES_USE_HW    =n
CONFIG_MBEDTLS_BIGNUM_USE_HW =n
CONFIG_MBEDTLS_ECC_USE_HW    =n
CONFIG_MBEDTLS_SHA1_USE_HW   =n
CONFIG_MBEDTLS_SHA256_USE_HW =n
CONFIG_MBEDTLS_SHA512_USE_HW =n

# Use LittleFS on Flash instead of FATFS on PSRAM
CONFIG_LITTLEFS = y
CONFIG_BFLB_MTD = y
CONFIG_PARTITION = y

# Disable FATFS and PSRAM
# CONFIG_FATFS = n
# CONFIG_NEWLIB_FATFS = n
# CONFIG_PSRAM = n

CONFIG_WIFI_IPERF=y
# CONFIG_WIFI_GATEWAY=y

# HTTP client support for upload command
CONFIG_HTTP=y
CONFIG_HTTP_CLIENT=y

ifeq ($(CHIP),bl618dg)
    CONFIG_ROMAPI             =n
    CONFIG_DUALCORE_DISABLE   =y
    CONFIG_WRAM_FOR_AP_SIZE   = 0x50000
    CONFIG_RAM_FOR_AP_SIZE    = 0x50000
endif
